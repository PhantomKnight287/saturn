BETTER_AUTH_URL=
# generate this using 'openssl rand -base64 32'
BETTER_AUTH_SECRET=
# postgresql database url
DATABASE_URL=
# the sender email address for email
EMAIL_SENDER=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# smtp mail host. only provide if you are not using mail proxy
MAIL_HOST=
# smtp password
MAIL_PASSWORD=
# smtp port
MAIL_PORT=
# smtp secure boolean
MAIL_SECURE=
# smtp user
MAIL_USER=
# base url for things like og image
NEXT_PUBLIC_BASE_URL=
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_PRODUCT_SLUG=
POLAR_WEBHOOK_SECRET=
S3_ACCESS_KEY_ID=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_SECRET_ACCESS_KEY=
# Featurebase SSO (from Featurebase dashboard → SSO settings)
FEATUREBASE_JWT_SECRET=
# Your Featurebase organization subdomain (e.g. "acme" → acme.featurebase.app)
NEXT_PUBLIC_FEATUREBASE_ORG=
