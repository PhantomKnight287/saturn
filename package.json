{
  "name": "better-auth-nextjs-starter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typegen": "next typegen",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "check": "ultracite check",
    "check:unsafe": "ultracite fix --unsafe",
    "check:write": "ultracite fix",
    "typecheck": "tsc --noEmit --incremental false",
    "check:spelling": "cspell -c .cspell.json --no-progress --no-summary --no-must-find-files --unique",
    "auth:generate": "bunx @better-auth/cli generate --config src/server/auth/index.ts --output src/server/db/schema/auth.ts --yes && bun check:unsafe src/server/db/schema/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "email:dev": "email dev --dir ./src/emails/templates",
    "postbuild": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@better-auth/api-key": "^1.5.5",
    "@better-auth/passkey": "^1.5.5",
    "@bprogress/next": "^3.2.12",
    "@cspell/dict-bash": "^4.2.2",
    "@cspell/dict-npm": "^5.2.36",
    "@databuddy/sdk": "^2.3.29",
    "@hono/zod-openapi": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@next/bundle-analyzer": "16.1.6",
    "@paralleldrive/cuid2": "^3.3.0",
    "@polar-sh/better-auth": "^1.8.3",
    "@polar-sh/sdk": "^0.47.0",
    "@react-email/components": "^1.0.9",
    "@react-pdf/renderer": "^4.3.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "@t3-oss/env-core": "^0.13.10",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "better-auth": "^1.5.4",
    "better-auth-ui": "npm:@daveyplate/better-auth-ui@latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-data-list": "^1.6.0",
    "cspell": "^9.7.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "evlog": "^2.8.0",
    "hono": "^4.12.12",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "16.1.6",
    "next-safe-action": "^8.1.8",
    "next-themes": "^0.4.6",
    "nextjs-better-unstable-cache": "^1.1.3",
    "nodemailer": "^8.0.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-email": "^5.2.9",
    "react-hook-form": "^7.71.2",
    "react-hotkeys-hook": "^5.2.4",
    "react-pdf": "^10.4.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "shadcn": "^4.0.8",
    "slugify": "^1.6.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-safe-area": "^1.3.0",
    "tiptap-extension-code-block-shiki": "^1.0.0",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@react-email/preview-server": "5.2.9",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "lefthook": "^2.1.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "core-js",
    "lefthook"
  ],
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
