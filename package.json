{
  "name": "saturn",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "check-types": "turbo run check-types",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "db:migrate": "dotenv -- turbo run db:migrate",
    "db:generate": "dotenv -- turbo run db:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/minimatch": "^6.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "5.9.3",
    "ultracite": "6.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "core-js",
    "unrs-resolver"
  ],
  "overrides": {
    "minimatch": "10.0.1"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
