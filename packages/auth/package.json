{
  "name": "@saturn/auth",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "1.3.4",
    "concurrently": "^9.2.1"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./permissions": {
      "import": "./dist/permissions.js",
      "require": "./dist/permissions.cjs",
      "types": "./dist/permissions.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs",
      "types": "./dist/auth.d.ts"
    }
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@saturn/db": "workspace:*",
    "better-auth": "1.4.6"
  },
  "scripts": {
    "build": "bun run ./src/build.ts && tsc",
    "dev": "concurrently --names \"Build\" \"Typecheck\" --colors \"blue,yellow\" \"bun run src/build.ts --watch\" \"tsc --watch\" "
  }
}