{
  "name": "@saturn/contracts",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "1.3.4",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/rpc": "^0.72.2",
