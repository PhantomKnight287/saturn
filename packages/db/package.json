{
  "name": "@saturn/db",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "1.3.4",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.4",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "minimatch": "10.1.1",
    "pg": "8.16.3",
    "pg-native": "^3.5.2",
    "postgres": "^3.4.7"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "require": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./drizzle": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "concurrently --names \"Build\" \"Typecheck\" --colors \"blue,yellow\" \"bun run src/build.ts --watch\" \"tsc --watch\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "build": "bun run src/build.ts && tsc"
  },
  "overrides": {
    "minimatch": "10.0.1"
  }
}
